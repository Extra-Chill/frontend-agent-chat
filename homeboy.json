{
  "id": "frontend-agent-chat",
  "changelog_target": "docs/CHANGELOG.md",
  "remote_path": "../wp-content/plugins/frontend-agent-chat",
  "extensions": {
    "wordpress": {}
  },
  "version_targets": [
    {
      "file": "frontend-agent-chat.php",
      "pattern": "Version:\\s*([\\d.]+)"
    },
    {
      "file": "frontend-agent-chat.php",
      "pattern": "FRONTEND_AGENT_CHAT_VERSION',\\s*'([\\d.]+)"
    }
  ]
}
